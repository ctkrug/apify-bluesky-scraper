{
  "title": "Bluesky Scraper",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "mode": {
      "title": "Mode",
      "type": "string",
      "editor": "select",
      "enum": ["author", "profile", "search"],
      "enumTitles": ["Author feed (no login)", "Profile stats (no login)", "Search posts (needs app password)"],
      "default": "author"
    },
    "handle": { "title": "Author handle", "type": "string", "description": "e.g. bsky.app (author/profile modes)", "editor": "textfield" },
    "query": { "title": "Search query", "type": "string", "description": "Keywords (search mode)", "editor": "textfield" },
    "limit": { "title": "Max records", "type": "integer", "default": 25, "maximum": 500 },
    "identifier": { "title": "Bluesky handle (for search auth)", "type": "string", "editor": "textfield" },
    "appPassword": { "title": "Bluesky app password (for search auth)", "type": "string", "editor": "textfield", "isSecret": true, "description": "Create at bsky.app → Settings → App Passwords. NOT your main password." }
  }
}
